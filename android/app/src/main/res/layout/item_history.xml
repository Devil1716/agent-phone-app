<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@drawable/ripple_glass"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Top row: category badge + timestamp -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/historyCategory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/badge_bg"
            android:paddingHorizontal="10dp"
            android:paddingVertical="3dp"
            android:text="NAVIGATE"
            android:textColor="@color/primary"
            android:textSize="10sp"
            android:textStyle="bold" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/historyTimestamp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:alpha="0.45"
            android:text="Just now"
            android:textColor="@color/onBackground"
            android:textSize="10sp" />
    </LinearLayout>

    <!-- Command text -->
    <TextView
        android:id="@+id/historyCommand"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"
        android:ellipsize="end"
        android:maxLines="2"
        android:text="User command"
        android:textColor="@color/onBackground"
        android:textSize="14sp"
        android:textStyle="bold"
        android:lineSpacingMultiplier="1.2" />

    <!-- Result summary -->
    <TextView
        android:id="@+id/historyResult"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"
        android:alpha="0.6"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="Result..."
        android:textColor="@color/onBackground"
        android:textSize="12sp" />

    <!-- Bottom row: strategy -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <View
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:background="@drawable/cot_step_indicator" />

        <TextView
            android:id="@+id/historyStrategy"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:text="FAST_PATH"
            android:textColor="@color/primary"
            android:textSize="10sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
