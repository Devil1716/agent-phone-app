<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/glass_card_bg"
    android:orientation="vertical"
    android:padding="16dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/historyCategory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="#1A2DD4BF"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            android:text="NAVIGATE"
            android:textColor="@color/primary"
            android:textSize="10sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/historyTimestamp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:alpha="0.5"
            android:text="Just now"
            android:textColor="@color/onBackground"
            android:textSize="10sp" />
    </RelativeLayout>

    <TextView
        android:id="@+id/historyCommand"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"
        android:ellipsize="end"
        android:maxLines="2"
        android:text="User command goes here"
        android:textColor="@color/onBackground"
        android:textSize="15sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/historyResult"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:alpha="0.7"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="Result summary..."
        android:textColor="@color/onBackground"
        android:textSize="13sp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginBottom="8dp"
        android:background="@color/glassStroke" />

    <TextView
        android:id="@+id/historyStrategy"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Strategy: AUTONOMOUS"
        android:textColor="@color/primary"
        android:textSize="11sp"
        android:textStyle="bold" />
</LinearLayout>
